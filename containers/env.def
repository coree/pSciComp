Bootstrap: docker
From: python:3.13-slim

%arguments
    VERSION=0.0.0

%files
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/
    uv.lock /app/
    src/ /app/src/
    config/ /app/config/
    scripts/ /app/scripts/

%setup
    # Create directories required by cluster mounts
    mkdir -p $APPTAINER_ROOTFS/apps
    mkdir -p $APPTAINER_ROOTFS/shares
    mkdir -p $APPTAINER_ROOTFS/scratch

%post
    # Install uv
    pip install uv

    # Move into app directory and install dependencies with explicit version
    cd /app
    SETUPTOOLS_SCM_PRETEND_VERSION={{ VERSION }} uv sync --no-dev


%environment
    # Make the virtualenv available
    export PATH="/app/.venv/bin:$PATH"
    # Tell uv not to try to update the environment at runtime
    export UV_NO_SYNC=1
    export UV_FROZEN=1

%runscript
    /app/.venv/bin/python /app/scripts/drafts/say_hello.py